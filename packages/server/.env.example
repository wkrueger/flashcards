DATABASE_URL="file:./dev.db"
BETTER_AUTH_SECRET="change-me-to-a-random-32-char-string"
BETTER_AUTH_URL="http://localhost:3001"
SERVER_PORT=3001
CLIENT_ORIGIN="http://localhost:5173"
DISABLE_USER_CREATION=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# Mailgun (leave blank in dev to log emails to stdout)
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_FROM="Cards <no-reply@example.com>"
MAILGUN_REGION=us

# Google OAuth (leave blank to disable Google SSO)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Set to 1 only for the Playwright e2e env to skip email verification
AUTH_E2E_AUTOVERIFY=0
