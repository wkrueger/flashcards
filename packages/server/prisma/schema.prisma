generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ---------- better-auth tables ----------
// Schemas chosen to match better-auth's default Prisma adapter.

model User {
  id            String   @id
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  plan          String   @default("free")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions Session[]
  accounts Account[]

  decks           Deck[]
  subjects        Subject[]
  tags            Tag[]
  importProcesses ImportProcess[]
}

enum TagOwnerType {
  SYSTEM
  USER
}

model Session {
  id        String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                    String    @id
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ---------- domain ----------

model Language {
  id                      Int     @id @default(autoincrement())
  name                    String  @unique
  englishName             String?
  emoji                   String
  speechRecognitionLocale String?

  decksAsDefaultFront           Deck[]          @relation("DeckDefaultFrontLanguage")
  decksAsDefaultBack            Deck[]          @relation("DeckDefaultBackLanguage")
  importProcessesAsDefaultFront ImportProcess[] @relation("ImportProcessDefaultFrontLanguage")
  importProcessesAsDefaultBack  ImportProcess[] @relation("ImportProcessDefaultBackLanguage")
}

model Deck {
  id                       String                 @id @default(cuid())
  name                     String
  userId                   String
  user                     User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  defaultFrontLanguageId   Int?
  defaultFrontLanguage     Language?              @relation("DeckDefaultFrontLanguage", fields: [defaultFrontLanguageId], references: [id], onDelete: SetNull)
  defaultBackLanguageId    Int?
  defaultBackLanguage      Language?              @relation("DeckDefaultBackLanguage", fields: [defaultBackLanguageId], references: [id], onDelete: SetNull)
  speechRecognitionEnabled Boolean                @default(true)
  inverseReviewEnabled     Boolean                @default(false)
  inverseReviewStreak      Int                    @default(0)
  subjects                 Subject[]
  cards                    Card[]
  reviewStats              ReviewStat[]
  createdAt                DateTime               @default(now())
  reviewStatUniqueCards    ReviewStatUniqueCard[]

  @@unique([userId, name])
}

model Subject {
  id              String    @id @default(cuid())
  deckId          String
  deck            Deck      @relation(fields: [deckId], references: [id], onDelete: Cascade)
  subject         String
  subjectKey      String
  randomKey       Int       @default(0)
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastSeenAt      DateTime?
  timesSeen       Int       @default(0)
  fixationLevel   String    @default("1")
  inverseReviewed Boolean   @default(false)
  cooldownAt      DateTime  @default(now())
  cards           Card[]

  @@unique([deckId, subjectKey])
  @@index([deckId, randomKey])
  @@index([deckId, cooldownAt, randomKey])
  @@index([userId, deckId])
}

model Card {
  id                    String                 @id @default(cuid())
  deckId                String
  deck                  Deck                   @relation(fields: [deckId], references: [id], onDelete: Cascade)
  subjectId             String
  subject               Subject                @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  front                 String
  frontHash             String
  back                  String
  genTemplate           String?
  lastSeenAt            DateTime?
  timesSeen             Int                    @default(0)
  createdAt             DateTime               @default(now())
  cardTags              CardTag[]
  reviewStatUniqueCards ReviewStatUniqueCard[]

  @@unique([subjectId, frontHash])
  @@index([subjectId, lastSeenAt])
  @@index([deckId])
}

model Tag {
  id        String       @id @default(cuid())
  ownerType TagOwnerType
  ownerKey  String
  userId    String?
  user      User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  cardTags  CardTag[]

  @@unique([ownerKey, name])
  @@index([ownerKey])
  @@index([userId])
}

model CardTag {
  cardId String
  tagId  String
  card   Card   @relation(fields: [cardId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([cardId, tagId])
  @@index([tagId])
}

enum ImportProcessStatus {
  UPLOADED
  ANALYZING
  AWAITING_CONFIGURATION
  VALIDATING
  IMPORTING
  SUCCEEDED
  FAILED
}

enum ImportCardTypeKind {
  BASIC
  CLOZE
}

enum WorkerJobType {
  ANALYZE_ANKI_IMPORT
  RUN_ANKI_IMPORT
}

enum WorkerJobStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
}

model ImportProcess {
  id                     String              @id @default(cuid())
  userId                 String
  user                   User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  status                 ImportProcessStatus @default(UPLOADED)
  filename               String
  fileSize               Int
  storagePath            String
  detectedCollectionFile String?
  deckName               String?
  defaultFrontLanguageId Int?
  defaultFrontLanguage   Language?           @relation("ImportProcessDefaultFrontLanguage", fields: [defaultFrontLanguageId], references: [id], onDelete: SetNull)
  defaultBackLanguageId  Int?
  defaultBackLanguage    Language?           @relation("ImportProcessDefaultBackLanguage", fields: [defaultBackLanguageId], references: [id], onDelete: SetNull)
  inverseReviewEnabled   Boolean?
  createdDeckId          String?
  rowCount               Int                 @default(0)
  selectedRowCount       Int                 @default(0)
  importedCardCount      Int                 @default(0)
  failedRowCount         Int                 @default(0)
  errorSummary           String?
  errorDetailsJson       String?
  completedAt            DateTime?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt

  cardTypes  ImportCardType[]
  workerJobs WorkerJob[]

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model ImportCardType {
  id               String             @id @default(cuid())
  processId        String
  process          ImportProcess      @relation(fields: [processId], references: [id], onDelete: Cascade)
  modelKey         String
  modelName        String
  modelKind        ImportCardTypeKind
  rowCount         Int
  fieldNamesJson   String
  sampleRowsJson   String
  selected         Boolean            @default(false)
  subjectField     String?
  cardMappingsJson String?
  pluginsJson      String?
  previewCardsJson String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@unique([processId, modelKey])
  @@index([processId])
}

model WorkerJob {
  id          String          @id @default(cuid())
  processId   String?
  process     ImportProcess?  @relation(fields: [processId], references: [id], onDelete: Cascade)
  type        WorkerJobType
  status      WorkerJobStatus @default(PENDING)
  attempts    Int             @default(0)
  error       String?
  availableAt DateTime        @default(now())
  startedAt   DateTime?
  finishedAt  DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([status, availableAt, createdAt])
  @@index([processId])
}

model ReviewStat {
  id          String                 @id @default(cuid())
  deckId      String
  deck        Deck                   @relation(fields: [deckId], references: [id], onDelete: Cascade)
  date        DateTime
  cardMinutes Int                    @default(0)
  cardCount   Int                    @default(0)
  uniqueCards ReviewStatUniqueCard[]

  @@unique([deckId, date])
  @@index([deckId, date])
}

model ReviewStatUniqueCard {
  id     String @id @default(cuid())
  deckId String
  deck   Deck   @relation(fields: [deckId], references: [id], onDelete: Cascade)

  cardId       String
  card         Card        @relation(fields: [cardId], references: [id], onDelete: Cascade)
  reviewStat   ReviewStat? @relation(fields: [reviewStatId], references: [id])
  reviewStatId String?

  @@unique([deckId, cardId])
  @@index([deckId, cardId])
}
