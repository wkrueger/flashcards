generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ---------- better-auth tables ----------
// Schemas chosen to match better-auth's default Prisma adapter.

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions Session[]
  accounts Account[]

  decks    Deck[]
  subjects Subject[]
  tags     Tag[]
}

model Session {
  id        String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                    String    @id
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ---------- domain ----------

model Language {
  id          Int    @id @default(autoincrement())
  name        String @unique
  englishName String?
  emoji       String

  decksAsDefaultFront Deck[] @relation("DeckDefaultFrontLanguage")
  decksAsDefaultBack  Deck[] @relation("DeckDefaultBackLanguage")
}

model Deck {
  id                    String    @id @default(cuid())
  name                  String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  defaultFrontLanguageId Int?
  defaultFrontLanguage  Language? @relation("DeckDefaultFrontLanguage", fields: [defaultFrontLanguageId], references: [id], onDelete: SetNull)
  defaultBackLanguageId  Int?
  defaultBackLanguage   Language? @relation("DeckDefaultBackLanguage", fields: [defaultBackLanguageId], references: [id], onDelete: SetNull)
  inverseReviewEnabled  Boolean   @default(false)
  cards                 Card[]
  createdAt             DateTime  @default(now())

  @@unique([userId, name])
}

model Subject {
  id            String    @id @default(cuid())
  subject       String
  subjectKey    String
  randomKey     Int       @default(0)
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastSeenAt    DateTime?
  timesSeen     Int       @default(0)
  fixationLevel String    @default("1")
  inverseReviewed Boolean @default(false)
  cooldownAt    DateTime  @default(now())
  cards         Card[]

  @@unique([userId, subjectKey])
  @@index([userId, randomKey])
  @@index([userId, cooldownAt, randomKey])
}

model Card {
  id         String    @id @default(cuid())
  deckId     String
  deck       Deck      @relation(fields: [deckId], references: [id], onDelete: Cascade)
  subjectId  String
  subject    Subject   @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  front      String
  frontHash  String
  back       String
  genTemplate String?
  lastSeenAt DateTime?
  timesSeen  Int       @default(0)
  createdAt  DateTime  @default(now())
  cardTags   CardTag[]

  @@unique([subjectId, frontHash])
  @@index([subjectId, lastSeenAt])
  @@index([deckId])
}

model Tag {
  id       String    @id @default(cuid())
  userId   String
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name     String
  cardTags CardTag[]

  @@unique([userId, name])
  @@index([userId])
}

model CardTag {
  cardId String
  tagId  String
  card   Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([cardId, tagId])
  @@index([tagId])
}
