{
  "name": "server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/main.ts",
  "exports": {
    ".": "./src/main.ts",
    "./router": "./src/domains/_app.router.ts"
  },
  "scripts": {
    "dev": "tsx watch --env-file=.env src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "tsx prisma/seed.ts",
    "send-test-email": "tsx --env-file=.env scripts/send-test-email.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@cards/shared": "workspace:*",
    "@fastify/cors": "^10.0.1",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@trpc/server": "^11.0.0-rc.659",
    "better-auth": "^1.1.7",
    "dayjs": "^1.11.20",
    "dotenv": "^17.4.2",
    "fastify": "^5.2.0",
    "form-data": "^4.0.5",
    "mailgun.js": "^13.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.8.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
