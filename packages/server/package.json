{
  "name": "server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/main.ts",
  "exports": {
    ".": "./src/main.ts",
    "./router": "./src/domains/_app.router.ts"
  },
  "scripts": {
    "dev": "tsx watch --env-file=.env src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "worker": "tsx --env-file=.env src/worker/main.ts",
    "worker:watch": "tsx watch --env-file=.env src/worker/main.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "extract:anki-phrases": "tsx scripts/extract-anki-phrases.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "tsx --env-file=.env prisma/seed.ts",
    "send-test-email": "tsx --env-file=.env scripts/send-test-email.ts"
  },
  "prisma": {
    "seed": "tsx --env-file=.env prisma/seed.ts"
  },
  "dependencies": {
    "@cards/shared": "workspace:*",
    "@fastify/cors": "^10.0.1",
    "@fastify/multipart": "^10.0.0",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@prisma/client-runtime-utils": "7.8.0",
    "@trpc/server": "^11.0.0-rc.659",
    "adm-zip": "^0.5.17",
    "better-auth": "^1.1.7",
    "better-sqlite3": "^12.9.0",
    "cac": "^7.0.0",
    "dayjs": "^1.11.20",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "fastify": "^5.2.0",
    "form-data": "^4.0.5",
    "mailgun.js": "^13.0.0",
    "openai": "^6.35.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.2",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.8.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
